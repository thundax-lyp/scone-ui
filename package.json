{
    "name": "scone-ui",
    "version": "0.1.0",
    "type": "module",
    "description": "Admin UI component library for React and Tailwind CSS.",
    "license": "Apache-2.0",
    "sideEffects": [
        "*.css",
        "dist/**/*.css"
    ],
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./styles.css": "./dist/styles.css",
        "./package-ai-guide": "./PACKAGE-AI-GUIDE.md",
        "./PACKAGE-AI-GUIDE.md": "./PACKAGE-AI-GUIDE.md",
        "./package.json": "./package.json"
    },
    "files": [
        "dist/index.js",
        "dist/index.cjs",
        "dist/index.d.ts",
        "dist/components/data-display",
        "dist/components/feedback-overlay",
        "dist/components/form",
        "dist/components/layout",
        "dist/components/media",
        "dist/components/navigation",
        "dist/lib",
        "dist/patterns",
        "dist/styles.css",
        "dist/styles",
        "dist/types",
        "PACKAGE-AI-GUIDE.md",
        "docs/10-specs",
        "README.md"
    ],
    "publishConfig": {
        "access": "public"
    },
    "packageManager": "pnpm@10.7.0",
    "engines": {
        "node": ">=22",
        "pnpm": ">=10"
    },
    "scripts": {
        "dev": "vite",
        "build": "pnpm build:js && pnpm build:types && pnpm build:styles",
        "build:js": "vite build",
        "build:styles": "mkdir -p dist/styles && cp src/styles.css dist/styles.css && cp src/styles/theme.css dist/styles/theme.css",
        "build:types": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && rm -rf dist/components/ui",
        "pack:check": "pnpm build && npm pack --dry-run",
        "prepack": "pnpm build",
        "preview": "vite preview",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint .",
        "test": "vitest run",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@fontsource-variable/geist": "^5.2.9",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "lucide-react": "^1.24.0",
        "next-themes": "^0.4.6",
        "radix-ui": "^1.6.2",
        "shadcn": "^4.13.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "tw-animate-css": "^1.4.0"
    },
    "peerDependencies": {
        "react": ">=18 <20",
        "react-dom": ">=18 <20"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tailwindcss/vite": "^4.1.18",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^26.1.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.3",
        "eslint": "^10.7.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "jsdom": "^29.1.1",
        "prettier": "^3.9.5",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "tailwindcss": "^4.1.18",
        "tsc-alias": "^1.8.17",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.63.0",
        "vite": "^8.1.4",
        "vitest": "^4.1.10"
    }
}
