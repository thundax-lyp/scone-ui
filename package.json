{
    "name": "scone-ui-workspace",
    "version": "0.1.1",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@10.7.0",
    "engines": {
        "node": ">=22",
        "pnpm": ">=10"
    },
    "scripts": {
        "dev": "pnpm --filter @scone-ui/example dev",
        "dev:docs": "pnpm --filter @scone-ui/docs dev",
        "build": "pnpm --filter scone-ui build",
        "build:example": "pnpm --filter @scone-ui/example build",
        "build:docs": "pnpm --filter @scone-ui/docs build",
        "pack:check": "pnpm --filter scone-ui pack:check",
        "preview": "pnpm --filter @scone-ui/example preview",
        "preview:docs": "pnpm --filter @scone-ui/docs preview",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint .",
        "test": "vitest run",
        "test:example": "pnpm --filter @scone-ui/example test",
        "typecheck": "pnpm --filter scone-ui typecheck && pnpm --filter @scone-ui/example typecheck && pnpm --filter @scone-ui/docs typecheck",
        "version:check": "node scripts/sync-workspace-version.mjs --check",
        "version:sync": "node scripts/sync-workspace-version.mjs --write"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tailwindcss/vite": "^4.1.18",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^26.1.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.3",
        "eslint": "^10.7.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "jsdom": "^29.1.1",
        "prettier": "^3.9.5",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "tailwindcss": "^4.1.18",
        "tsc-alias": "^1.8.17",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.63.0",
        "vite": "^8.1.4",
        "vitest": "^4.1.10"
    }
}
