{
    "name": "scone-ui",
    "version": "0.1.1",
    "type": "module",
    "description": "Admin UI component library for React and Tailwind CSS.",
    "license": "Apache-2.0",
    "sideEffects": [
        "*.css",
        "dist/**/*.css"
    ],
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./styles.css": "./dist/styles.css",
        "./default.theme.css": "./dist/default.theme.css",
        "./styles/theme.css": "./dist/styles/theme.css",
        "./PACKAGE-AI-GUIDE.md": "./PACKAGE-AI-GUIDE.md",
        "./package.json": "./package.json"
    },
    "files": [
        "dist/index.js",
        "dist/index.cjs",
        "dist/index.d.ts",
        "dist/components/data-display",
        "dist/components/feedback-overlay",
        "dist/components/form",
        "dist/components/layout",
        "dist/components/media",
        "dist/components/navigation",
        "dist/lib",
        "dist/patterns",
        "dist/styles.css",
        "dist/default.theme.css",
        "dist/styles",
        "dist/types",
        "PACKAGE-AI-GUIDE.md",
        "README.md"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "pnpm build:js && pnpm build:types && pnpm build:styles",
        "build:js": "vite build",
        "build:styles": "mkdir -p dist/styles && cp src/styles.css dist/styles.css && cp src/default.theme.css dist/default.theme.css && cp src/styles/theme.css dist/styles/theme.css",
        "build:types": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && rm -rf dist/components/ui",
        "pack:check": "pnpm build && npm pack --dry-run",
        "prepack": "pnpm build",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@fontsource-variable/geist": "^5.2.9",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "lucide-react": "^1.24.0",
        "next-themes": "^0.4.6",
        "radix-ui": "^1.6.2",
        "shadcn": "^4.13.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "tw-animate-css": "^1.4.0"
    },
    "peerDependencies": {
        "react": ">=18 <20",
        "react-dom": ">=18 <20"
    }
}
