{
    "compilerOptions": {
        "target": "ES2022",
        "useDefineForClassFields": true,
        "lib": ["DOM", "DOM.Iterable", "ES2022"],
        "allowJs": false,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@/*": ["./packages/scone-ui/src/*"],
            "scone-ui": ["./packages/scone-ui/src/index.ts"],
            "scone-ui/styles.css": ["./packages/scone-ui/src/styles.css"]
        },
        "types": ["node", "vitest/globals", "@testing-library/jest-dom"]
    },
    "include": [
        "packages/scone-ui/src",
        "packages/scone-ui/vite.config.ts",
        "apps/example/src",
        "apps/example/vite.config.ts",
        "apps/scone-docs/docusaurus.config.ts",
        "apps/scone-docs/sidebars.ts",
        "vitest.config.ts",
        "tailwind.config.ts",
        "eslint.config.mjs"
    ]
}
