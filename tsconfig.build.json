{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "declaration": true,
        "declarationMap": false,
        "emitDeclarationOnly": true,
        "outDir": "dist",
        "rootDir": "src",
        "types": ["react", "react-dom"]
    },
    "include": [
        "src/index.ts",
        "src/components/**/*.ts",
        "src/components/**/*.tsx",
        "src/lib/**/*.ts",
        "src/lib/**/*.tsx",
        "src/patterns/**/*.ts",
        "src/patterns/**/*.tsx",
        "src/types/**/*.ts"
    ],
    "exclude": [
        "src/**/*.test.ts",
        "src/**/*.test.tsx",
        "src/app.tsx",
        "src/main.tsx",
        "src/test/**"
    ]
}
